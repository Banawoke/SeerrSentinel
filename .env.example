# ─────────────────────────────────────────────
#  SeerrSentinel — Environment variables
# ─────────────────────────────────────────────

# Jellyseerr
JELLYSEER_API_KEY="your_jellyseerr_api_key"
JELLYSEER_URL="http://localhost:5055"

# TMDB 
TMDB_API_KEY="your_tmdb_api_key"

# Radarr
RADARR_API_KEY="your_radarr_api_key"
RADARR_URL="http://localhost:7878"

# Sonarr
SONARR_API_KEY="your_sonarr_api_key"
SONARR_URL="http://localhost:8989"

# Media import (sentinel_import)
DOWNLOADS_PATH="/downloads"
PUID=1000
PGID=1000

# ─────────────────────────────────────────────
#  Optional settings (defaults shown)
# ─────────────────────────────────────────────
RELEASE_BUFFER_DAYS=7           # Days after release before considering cleanup
DELETION_DELAY_DAYS=2           # Grace period before deleting missing media
KEEP_REQUESTS_OLDER_THAN_DAYS=14  # Keep Jellyseerr requests older than N days after this day it's no longuer deleted 
